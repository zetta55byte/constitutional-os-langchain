# CARE environment variable reference
# Copy to .env and customise:
#   cp .env.example .env

# ── Server ──────────────────────────────────────────────────────────────────
CARE_HOST=0.0.0.0
CARE_PORT=8000

# ── Curvature backend ────────────────────────────────────────────────────────
# numpy    — finite differences, always available, O(h²) error
# jax      — forward-over-reverse AD, requires jax>=0.4.25
# jax-xla  — hcderiv one-pass XLA Hessian, requires hcderiv[jax]>=0.4.0
CARE_CURVATURE_BACKEND=numpy

# ── Constitutional OS integration ────────────────────────────────────────────
# Set CARE_COS_ENABLED=true and point CARE_COS_ENDPOINT at a live COS Runtime.
# While false, /apply runs in dry-run mode and logs what would be applied.
CARE_COS_ENABLED=false
CARE_COS_ENDPOINT=http://localhost:9000

# ── Risk thresholds ──────────────────────────────────────────────────────────
# |λ| below CARE_SOFT_LAMBDA is classified as a "soft direction" (potential escape route)
CARE_SOFT_LAMBDA=1.0

# R(x) above CARE_HIGH_RISK triggers MFA enforcement recommendation
CARE_HIGH_RISK=10.0

# Maximum encoded state dimension
CARE_MAX_STATE_DIM=64

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Docker Compose ───────────────────────────────────────────────────────────
# Exposed ports (change if you have port conflicts)
NOTEBOOK_PORT=8888
COS_PORT=9000
